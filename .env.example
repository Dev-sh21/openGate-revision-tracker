# ================================================
# Revision Tracker - Environment Variables Guide
# ================================================
# Copy this file to .env and fill in your values.

# ----------------------------
# DATABASE (Required)
# ----------------------------
# Local Docker: postgresql://postgres:postgres@localhost:5432/revision_tracker?schema=public
# Supabase/Neon/Railway: replace with your connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/revision_tracker?schema=public"

# ----------------------------
# NEXTAUTH (Required)
# ----------------------------
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3001"

# ----------------------------
# GOOGLE OAUTH (Optional - for Calendar & Sheets sync)
# ----------------------------
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable these APIs:
#    - Google Calendar API
#    - Google Sheets API
#    - Google People API (for email access)
# 3. Create OAuth 2.0 Client ID (Web Application)
# 4. Add authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----------------------------
# NOTION OAUTH (Optional - for Notion database sync)
# ----------------------------
# 1. Go to https://www.notion.so/my-integrations
# 2. Create a new integration (Public type for OAuth)
# 3. Add redirect URI: http://localhost:3001/api/auth/notion/callback
# Alternatively: Use an Internal Integration Token in the Settings page (no OAuth setup needed)
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""

# ----------------------------
# CRON SECRET (Required - protects cron endpoints)
# ----------------------------
CRON_SECRET="your-cron-secret-key"

# ----------------------------
# PUBLIC URL (Required)
# ----------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3001"
